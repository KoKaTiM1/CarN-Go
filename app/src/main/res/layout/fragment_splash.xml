<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_splash_screen"
    android:fillViewport="true">

    <LinearLayout
        android:id="@+id/layoutSplashContent"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:paddingHorizontal="24dp"
        android:paddingTop="20dp"
        android:paddingBottom="24dp">

        <TextView
            android:id="@+id/btnSkipSplash"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="end"
            android:background="@drawable/bg_splash_skip"
            android:paddingHorizontal="14dp"
            android:paddingVertical="8dp"
            android:text="@string/splash_skip"
            android:textColor="@color/white"
            android:textSize="13sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvSplashBadge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:text="@string/splash_badge"
            android:textAllCaps="true"
            android:textColor="#B9D8FF"
            android:textSize="11sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvSplashTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:gravity="center"
            android:text="@string/splash_title"
            android:textColor="@color/white"
            android:textSize="28sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvSplashSubtitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:gravity="center"
            android:text="@string/splash_subtitle"
            android:textColor="#D9E8FF"
            android:textSize="14sp" />

        <FrameLayout
            android:id="@+id/layoutSplashCircle"
            android:layout_width="280dp"
            android:layout_height="280dp"
            android:layout_marginTop="18dp"
            android:foregroundGravity="center">

            <View
                android:id="@+id/viewPulseOuter"
                android:layout_width="280dp"
                android:layout_height="280dp"
                android:layout_gravity="center"
                android:background="@drawable/bg_splash_wave_outer" />

            <View
                android:id="@+id/viewPulseInner"
                android:layout_width="220dp"
                android:layout_height="220dp"
                android:layout_gravity="center"
                android:background="@drawable/bg_splash_wave_inner" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSearchNearby"
                android:layout_width="168dp"
                android:layout_height="168dp"
                android:layout_gravity="center"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:text="@string/splash_search_button"
                android:textAlignment="center"
                android:textColor="@color/white"
                android:textSize="20sp"
                android:textStyle="bold"
                app:backgroundTint="#1F7BFF"
                app:icon="@android:drawable/ic_menu_mylocation"
                app:iconGravity="textTop"
                app:iconPadding="12dp"
                app:iconTint="@color/white"
                app:rippleColor="#66FFFFFF"
                app:shapeAppearanceOverlay="@style/ShapeAppearance.Material3.Corner.Full" />
        </FrameLayout>

        <TextView
            android:id="@+id/tvSplashStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:gravity="center"
            android:text="@string/splash_status_idle"
            android:textColor="#D9E8FF"
            android:textSize="14sp" />

        <LinearLayout
            android:id="@+id/layoutSplashResults"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:background="@drawable/bg_splash_results_panel"
            android:orientation="vertical"
            android:padding="16dp"
            android:visibility="gone">

            <TextView
                android:id="@+id/tvSplashResultsTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/splash_results_title"
                android:textColor="@color/white"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvSplashResultsSubtitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="@string/splash_results_subtitle"
                android:textColor="#D9E8FF"
                android:textSize="13sp" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvSplashCars"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:nestedScrollingEnabled="false" />
        </LinearLayout>
    </LinearLayout>
</androidx.core.widget.NestedScrollView>

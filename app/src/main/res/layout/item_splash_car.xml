<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="3dp"
    android:clickable="true"
    android:focusable="true"
    app:cardBackgroundColor="#1E2D56"
    app:cardCornerRadius="14dp"
    app:cardElevation="0dp"
    app:strokeColor="#354A82"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="5dp">

        <ImageView
            android:id="@+id/ivSplashCarImage"
            android:layout_width="42dp"
            android:layout_height="38dp"
            android:scaleType="centerCrop" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvSplashCarName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:maxLines="1"
                android:textColor="@color/white"
                android:textSize="13sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvSplashCarDistance"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="1dp"
                android:ellipsize="end"
                android:maxLines="1"
                android:textColor="#D9E8FF"
                android:textSize="10sp" />

            <TextView
                android:id="@+id/tvSplashCarType"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:background="@drawable/bg_splash_type_chip"
                android:paddingHorizontal="6dp"
                android:paddingVertical="1dp"
                android:textColor="@color/white"
                android:textSize="8sp" />
        </LinearLayout>

        <TextView
            android:id="@+id/tvSplashCarPrice"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#8BC0FF"
            android:textSize="11sp"
            android:textStyle="bold" />
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
